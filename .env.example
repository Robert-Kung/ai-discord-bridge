# 從 https://discord.com/developers/applications 各自建立 Application → Bot 拿 token
DISCORD_BOT_A_TOKEN=
DISCORD_BOT_B_TOKEN=

# 進入 Discord client → 開發者模式 → 右鍵 #ai-chat channel → 「複製頻道 ID」
DISCORD_CHANNEL_ID=

# 允許驅動 bot 的 Discord user id（逗號分隔）。bot 互答透過 MAX_BOT_TURNS 控制，不受此限。
ALLOWED_USER_IDS=

# A/B 互答總輪數上限（每次有人類發言重置；也是 !discuss 的最大輪數）
MAX_BOT_TURNS=6

# 單次 claude -p 呼叫的 timeout（秒）
CLAUDE_TIMEOUT=300

# 自動 flush 觸發門檻：每 N 則訊息累計，B 會在背景跑 summary
AUTO_FLUSH_THRESHOLD=20

# plan-then-execute 等使用者 react 的最長時間（秒）
PLAN_REACTION_TIMEOUT=300
