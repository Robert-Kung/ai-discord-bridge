# 從 https://discord.com/developers/applications 各自建立 Application → Bot 拿 token
DISCORD_BOT_A_TOKEN=
DISCORD_BOT_B_TOKEN=

# 進入 Discord client → 開發者模式 → 右鍵 #ai-chat channel → 「複製頻道 ID」
DISCORD_CHANNEL_ID=

# 允許驅動 bot 的 Discord user id（逗號分隔）。留空 = fail-closed 拒絕啟動。
# A/B 互答不受此限（由 MAX_BOT_TURNS 控制）；第三方 bot/webhook 仍受此限（被擋）。
ALLOWED_USER_IDS=

# ── 認證模式（雙模式）─────────────────────────────────────────────
# 留空/false（預設）= 訂閱模式：各 bot 用其 CLAUDE_CONFIG_DIR 內的 OAuth 憑證。
# true = API key 模式：注入下列 per-bot key，改走 Developer Platform 計費。
#   ⚠️ API key 模式下 key 會進 subprocess 環境 → bypass 的 printenv 讀得到，
#      請用有額度上限的 key（見 SECURITY.md §6）。開啟但缺 key 會拒絕啟動。
USE_API_KEY=false
ANTHROPIC_API_KEY_A=
ANTHROPIC_API_KEY_B=

# A/B 互答總輪數上限（每次有人類發言重置；也是 !discuss 的最大輪數）
MAX_BOT_TURNS=6

# 單次 claude -p 呼叫的 timeout（秒）
CLAUDE_TIMEOUT=300

# 自動 flush 觸發門檻：每 N 則訊息累計，B 會在背景跑 summary
AUTO_FLUSH_THRESHOLD=20

# token 門檻（opus[1m] 1M context 三段式；設 0 關閉該段）
FLUSH_TOKEN_THRESHOLD=400000     # 寫 summary 存檔、保留對話線
RESET_TOKEN_THRESHOLD=700000     # 濃縮 session + 重置（真 autocompact）
HARD_RESET_TOKEN_THRESHOLD=900000 # 濃縮失敗也強制重置（逃生口）

# plan-then-execute 等使用者 react 的最長時間（秒）
PLAN_REACTION_TIMEOUT=300

# ── 執行權限（M1 硬化）────────────────────────────────────────────
# 完整 bypass 是 opt-in tier，預設關閉（結構性不可達）。設 true 才允許
# whitelisted 使用者開 bypass；在那之前用 edit（可寫檔/執行，受 settings.json
# 的 permissions.deny 約束）。見 SECURITY.md §3/§4。
ENABLE_BYPASS_TIER=false

# M4 逐指令核可 tier（opt-in，預設關閉）。設 true 後可用 `!mode approve`：claude 跑在
# default 權限模式、掛 MCP approver——非白名單指令（見 approver-allowlist.json）會丟
# Discord 等 whitelisted 使用者按 ✅ 才執行，逾時/出錯一律拒絕（fail-closed）。這是
# headless 下唯一能把執行限制在某個指令集的機制。見 SECURITY.md。
ENABLE_APPROVER_TIER=false

# 啟動 canary：證明 --settings 的 deny family 真的載入了（claude 對驗證失敗的
# settings 檔會無聲忽略）。canary 沒通過 = fail-closed 拒絕啟動。
# 只在離線開發（無法跑 claude）時設 1 跳過 —— 正式部署請保持不設。
# BRIDGE_SKIP_CANARY=1
#
# 可選：覆寫 server 端安全設定檔路徑（預設容器內 /home/user/.claude-bridge-settings.json，
# 否則用 repo 內 settings.json）。
# BRIDGE_SETTINGS_PATH=
